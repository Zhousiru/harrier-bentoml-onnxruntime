# Authentication
API_KEY=replace-with-a-long-random-secret

# Model path inside the container
MODEL_DIR=/models/harrier
ONNX_MODEL_FILE=onnx/model_quantized.onnx

# Public model identity. MODEL_ALIASES is a comma-separated list and may be empty.
SERVED_MODEL_NAME=harrier-0.6b-int8
MODEL_ALIASES=
EXPECTED_DIMENSIONS=1024

# Request validation and tokenization
MAX_LENGTH=512
MAX_BATCH_SIZE=8

# BentoML API wrapper
API_WORKERS=1
API_THREADS=1
MAX_CONCURRENCY=8
REQUEST_TIMEOUT=120

# BentoML model service. Keep one worker for an 8-vCPU CPU deployment unless
# ORT_INTRA_OP_THREADS is reduced accordingly.
MODEL_WORKERS=1
MODEL_THREADS=1
MODEL_MAX_CONCURRENCY=8

# Adaptive batching. Set to 0 to disable without changing the public API.
ADAPTIVE_BATCHING=1
ADAPTIVE_MAX_BATCH_SIZE=8
ADAPTIVE_MAX_LATENCY_MS=10

# ONNX Runtime CPU threading
ORT_INTRA_OP_THREADS=8
ORT_INTER_OP_THREADS=1
ORT_DISABLE_SPINNING=1
WARMUP=1

# Offline/runtime behavior
TOKENIZERS_PARALLELISM=false
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
BENTOML_DO_NOT_TRACK=true
